{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Open with Live Server",
            "type": "chrome",
            "request": "launch",
            "url": "http://127.0.0.1:5500/index.html",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start Live Server"
        },
        {
            "name": "Open index.html in Browser",
            "type": "chrome",
            "request": "launch",
            "file": "${workspaceFolder}/index.html"
        }
    ]
}